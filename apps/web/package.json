{
  "name": "synapse2-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "pnpm exec serve out",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate": "pnpm check && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^16.2.10",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "serve": "^14.2.5",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.3.4",
    "typescript": "^7",
    "vitest": "^4.1.10"
  },
  "pnpm": {
