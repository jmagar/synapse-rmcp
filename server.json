{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.dinglebear/synapse-rmcp",
  "title": "Synapse RMCP",
  "description": "Rust MCP and CLI server for Docker, host inspection, SSH, logs, ZFS, and safe file operations.",
  "version": "0.5.4",
  "websiteUrl": "https://github.com/jmagar/synapse",
  "repository": {
    "url": "https://github.com/jmagar/synapse",
    "source": "github",
    "id": "1247261737"
  },
  "icons": [
    {
      "src": "https://avatars.githubusercontent.com/u/38927646?v=4",
      "mimeType": "image/png",
      "sizes": [
        "460x460"
      ],
      "theme": "dark"
    }
  ],
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "synapse-rmcp",
      "version": "0.5.4",
      "runtimeHint": "npx",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "Run Synapse RMCP over stdio.",
          "format": "string",
          "isRequired": true,
          "isSecret": false,
          "isRepeated": false
        }
      ],
      "environmentVariables": [
        {
          "name": "SYNAPSE_HOME",
          "description": "Optional Synapse appdata directory.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "~/.synapse2"
        },
        {
          "name": "SYNAPSE_HOSTS_CONFIG",
          "description": "Inline host topology as a JSON array.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "SYNAPSE_CONFIG_FILE",
          "description": "Path to a host configuration file.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "SYNAPSE_RMCP_VERSION",
          "description": "Optional GitHub release tag override for the downloaded Synapse binary.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "placeholder": "v0.5.3"
        },
        {
          "name": "SYNAPSE_RMCP_REPO",
          "description": "Optional GitHub owner/repo override for release asset downloads.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "jmagar/synapse",
          "placeholder": "jmagar/synapse"
        },
        {
          "name": "SYNAPSE_RMCP_RELEASE_BASE_URL",
          "description": "Optional release download base URL override.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "RUST_LOG",
          "description": "Tracing filter for Synapse logs.",
          "format": "string",
          "isRequired": false,
          "isSecret": false,
          "default": "info,rmcp=warn",
          "placeholder": "info,rmcp=warn"
        }
      ],
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "namespace": "ai.dinglebear",
      "dnsDomain": "dinglebear.ai",
      "distribution": {
        "npm": "synapse-rmcp@0.5.4",
        "nodePackage": "synapse-rmcp"
      },
      "buildInfo": {
        "version": "0.5.4",
        "repository": "https://github.com/jmagar/synapse"
      }
    }
  }
}
