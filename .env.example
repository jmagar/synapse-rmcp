# =============================================================================
# .env.synapse2 — Secrets and URLs for the Example MCP server
#
# TEMPLATE: Rename SYNAPSE_* throughout to your service's prefix.
#           Replace "synapse2" with your service name.
#
# SPLIT PHILOSOPHY — Rule of thumb:
#   Secrets and URLs go here (.env), everything else in config.toml.
#   Never put secrets in config.toml (it's checked into git).
#   Never put non-secret config here (it becomes hard to track).
#
# Concretely:
#   .env         → API URLs, API keys, tokens, OAuth credentials, passwords
#   config.toml  → Ports, bind addresses, feature flags, tuning knobs,
#                  timeouts, log levels, retention settings
#
# Usage:
#   cp .env.synapse2 .env
#   # Edit .env — fill in real values
#   # .env is in .gitignore; never commit it
# =============================================================================

# ── Upstream service ──────────────────────────────────────────────────────────
# TEMPLATE: These are the credentials for the remote service this MCP server
#           wraps. Rename to match your service (e.g. MYSERVICE_API_URL).
#
#           SYNAPSE_API_URL — full base URL of the remote API
#             e.g. https://api.synapse2.com/v1   (REST)
#             e.g. https://graphql.synapse2.com/graphql  (GraphQL)
#
#           SYNAPSE_API_KEY — API key / bearer token for the remote service.
#             Generate one in your service's developer console.
#             In src/synapse2.rs, this is passed as a header or query param.

SYNAPSE_API_URL=https://api.synapse2.com/v1
SYNAPSE_API_KEY=your-api-key-here

# ── MCP HTTP server ───────────────────────────────────────────────────────────
# SYNAPSE_MCP_TOKEN — static bearer token that MCP clients must present.
#   Every request to /mcp must include: Authorization: Bearer <this-value>
#   Generate with: openssl rand -hex 32   or   just gen-token
#   Omit (or set SYNAPSE_MCP_NO_AUTH=true) for loopback-only dev mode only.

# SYNAPSE_MCP_TOKEN=    # generate with: openssl rand -hex 32   or   just gen-token

# Bind host (default: 127.0.0.1 — loopback only). Set to 0.0.0.0 for external access.
# SYNAPSE_MCP_HOST=127.0.0.1

# Bind port (default: 40060).
# SYNAPSE_MCP_PORT=40060

# Disable auth entirely. ONLY safe when the server is bound to 127.x.
# Set to true only for local development when you control the machine.
# SYNAPSE_MCP_NO_AUTH=false

# Trusted-gateway no-auth mode. Set to true when behind a reverse proxy that
# enforces its own auth (e.g. Authelia, Traefik Forward Auth). Non-loopback only.
# SYNAPSE_NOAUTH=false

# Auth mode: "bearer" (default) or "oauth".
# SYNAPSE_MCP_AUTH_MODE=bearer

# Extra Host header values accepted by the server (comma-separated).
# SYNAPSE_MCP_ALLOWED_HOSTS=

# Extra CORS origins accepted by the server (comma-separated).
# SYNAPSE_MCP_ALLOWED_ORIGINS=

# ── OAuth (Google) ────────────────────────────────────────────────────────────
# TEMPLATE: Only needed when SYNAPSE_MCP_AUTH_MODE=oauth in config.toml.
#           Leave commented out for bearer-token-only mode (the simpler default).
#
# Steps to enable OAuth:
#   1. Create a Web application OAuth client at console.cloud.google.com
#   2. Add your redirect URIs (plugin-setup.sh does this automatically)
#   3. Set SYNAPSE_MCP_AUTH_MODE=oauth in config.toml
#   4. Fill in the values below

# Public URL of your MCP server (used as OAuth issuer / resource metadata URL).
# Must be reachable from clients. Required in OAuth mode.
# SYNAPSE_MCP_PUBLIC_URL=https://myservice.synapse2.com

# Google OAuth 2.0 credentials
# SYNAPSE_MCP_GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com
# SYNAPSE_MCP_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Bootstrap admin email — first allowed Google account for OAuth
# SYNAPSE_MCP_AUTH_ADMIN_EMAIL=admin@synapse2.com

# ── Docker runtime ────────────────────────────────────────────────────────────
# These are read by docker-compose.yml and entrypoint.sh, not by the binary.
# PUID=1000
# PGID=1000
# DOCKER_NETWORK=mcp
# VERSION=latest

# ── Logging ───────────────────────────────────────────────────────────────────
# TEMPLATE: Adjust as needed. info is a good default for production.
#           Use debug for development, warn for high-throughput servers.
# RUST_LOG=info
# RUST_LOG=info,rmcp=warn,synapse2=debug

# Disable ANSI color in console output.
# NO_COLOR=1

# Force ANSI color even when stderr is not a TTY.
# FORCE_COLOR=1
